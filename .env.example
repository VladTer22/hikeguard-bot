# Required
BOT_TOKEN=
ADMIN_CHAT_ID=

# Quarantine
QUARANTINE_HOURS=24

# Spam detection
SPAM_THRESHOLD=7

# Gemini API (optional — bot works without it)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT=10

# Moderation
MUTE_DURATION_MINUTES=60
BAN_ON_STRIKE=2

# Database
DB_PATH=data/hikeguard.db
