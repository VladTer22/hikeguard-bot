# Required
BOT_TOKEN=
ADMIN_CHAT_ID=

# Quarantine
QUARANTINE_HOURS=24

# Spam detection
SPAM_THRESHOLD=7

# Gemini API (optional — bot works without it)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_TIMEOUT=10

# Moderation
MUTE_DURATION_MINUTES=60
BAN_ON_STRIKE=3

# Database
DB_PATH=data/hikeguard.db

# Join request gate
JOIN_GATE_ENABLED=true
RAID_THRESHOLD=10
RAID_WINDOW_SEC=60
RAID_MODE_MINUTES=20
AUTO_DECLINE_SCORE=5
AUTO_APPROVE_SCORE=-1
RAID_ANNOUNCE_INTERVAL_SEC=600

# Member gate — instant ban at chat_member event when bots bypass approval-link
MEMBER_GATE_ENABLED=true
MEMBER_AUTO_BAN_SCORE=10
